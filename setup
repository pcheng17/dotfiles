#!/usr/bin/env bash
set -euo pipefail

DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export DOTFILES_DIR

source "${DOTFILES_DIR}/helper/log.sh"

MODE=""
RUN_PACKAGES=true
RUN_LINKS=true

for arg in "$@"; do
    case "$arg" in
        home|work) MODE="$arg" ;;
        --packages-only) RUN_LINKS=false ;;
        --links-only) RUN_PACKAGES=false ;;
        *) printf "Unknown argument: %s\n" "$arg"; exit 1 ;;
    esac
done

if [[ -z "$MODE" ]]; then
    printf "Usage: %s [home|work] [--packages-only|--links-only]\n" "$0"
    exit 1
fi

export MODE
OS="$(uname -s)"

IS_ARCH=false
if [[ "$OS" == "Linux" && -f /etc/os-release ]]; then
    OS_ID="$(. /etc/os-release && echo "${ID:-}")"
    OS_ID_LIKE="$(. /etc/os-release && echo "${ID_LIKE:-}")"
    if [[ "$OS_ID" == "arch" || "$OS_ID_LIKE" == *"arch"* ]]; then
        IS_ARCH=true
    fi
fi
export IS_ARCH

log_info "Detected OS: $OS${OS_ID:+ ($OS_ID)}"

if [[ "$RUN_PACKAGES" == true ]]; then
    case "$OS" in
        Darwin) source "${DOTFILES_DIR}/scripts/packages-macos.sh" ;;
        Linux)
            if [[ "$IS_ARCH" == true ]]; then
                source "${DOTFILES_DIR}/scripts/packages-arch.sh"
            else
                source "${DOTFILES_DIR}/scripts/packages-linux.sh"
            fi
            ;;
        *)      printf "Unsupported OS: %s\n" "$OS"; exit 1 ;;
    esac
fi

if [[ "$RUN_LINKS" == true ]]; then
    source "${DOTFILES_DIR}/scripts/links.sh"
fi
